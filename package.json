{
  "name": "real-house",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sitemaps && tsc && vite build",
    "preview": "vite preview",
    "server": "tsx server/src/index.ts",
    "server:dev": "tsx watch server/src/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "sitemaps": "tsx scripts/generate-sitemaps.ts",
    "indexnow": "tsx scripts/submit-indexnow.ts",
    "deploy": "npm run build && npm run indexnow"
  },
  "dependencies": {
    "@types/leaflet.markercluster": "^1.5.6",
    "gsap": "^3.12.5",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lenis": "^1.1.13"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "concurrently": "^9.2.1",
    "lightningcss": "^1.31.1",
    "sass": "^1.77.0",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
